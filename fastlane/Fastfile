default_platform(:ios)

IOS_APP_ID = "bontecou.time.mdIOS"
MAC_APP_ID = "com.bontecou.time.md"
API_KEY_ID = "T7KGDK4Y4V"
API_ISSUER_ID = "6c3b3640-c6bf-40a9-b6e5-57cda2c7776e"
API_KEY_PATH = "/Users/codybontecou/.private_keys/AuthKey_T7KGDK4Y4V.p8"

def connect_api_key
  app_store_connect_api_key(
    key_id: API_KEY_ID,
    issuer_id: API_ISSUER_ID,
    key_filepath: API_KEY_PATH,
    in_house: false
  )
end

# ──────────────────────────────────────────────
# iOS
# ──────────────────────────────────────────────
platform :ios do
  desc "Show current app info on App Store Connect"
  lane :info do
    connect_api_key
    app = Spaceship::ConnectAPI::App.find(IOS_APP_ID)
    if app
      UI.message("App: #{app.name} (#{app.bundle_id})")
      edit = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      if edit
        UI.message("Edit version: #{edit.version_string} — state: #{edit.app_store_state}")
        localizations = edit.get_app_store_version_localizations
        localizations.each do |loc|
          UI.message("  Locale: #{loc.locale}")
          sets = loc.get_app_screenshot_sets
          sets.each do |set|
            UI.message("    #{set.screenshot_display_type}: #{set.app_screenshots.count} screenshots")
          end
        end
      else
        UI.message("No edit version found")
      end
      live = app.get_live_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      if live
        UI.message("Live version: #{live.version_string} — state: #{live.app_store_state}")
      else
        UI.message("No live version found")
      end
    else
      UI.message("App not found on App Store Connect")
    end
  end

  desc "Build iOS app for App Store"
  lane :build do
    connect_api_key
    build_app(
      project: "time.md.xcodeproj",
      scheme: "time.mdIOS",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "time.mdIOS.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "67KC823C9A"
      }
    )
  end

  desc "Upload iOS build to App Store Connect"
  lane :upload do
    connect_api_key
    upload_to_app_store(
      api_key: connect_api_key,
      ipa: "build/ios/time.mdIOS.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Build and upload iOS"
  lane :ship do
    build
    upload
  end

  desc "Upload metadata only"
  lane :upload_metadata do
    connect_api_key
    deliver(
      app_identifier: IOS_APP_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload screenshots only"
  lane :upload_screenshots do
    connect_api_key
    deliver(
      app_identifier: IOS_APP_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload metadata + screenshots"
  lane :upload_all do
    connect_api_key
    deliver(
      app_identifier: IOS_APP_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Submit for review"
  lane :submit do
    connect_api_key
    deliver(
      app_identifier: IOS_APP_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      platform: "ios",
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end

