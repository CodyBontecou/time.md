{
  "manifest_version": 3,
  "name": "time.md enhanced blocking",
  "version": "0.1.0",
  "description": "Optional real-time URL detection for time.md exponential website blocking.",
  "permissions": ["nativeMessaging", "tabs", "webNavigation"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "time.md blocking"
  }
}
