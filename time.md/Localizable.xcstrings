    "time.md can now track your screen time.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "time.md ahora puede rastrear tu tiempo de pantalla."
          }
        }
      }
    },
    "time.md can track your iPhone screen time directly, giving you detailed insights into your digital habits.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "time.md puede rastrear directamente el tiempo de pantalla de tu iPhone, dándote información detallada sobre tus hábitos digitales."
          }
        }
      }
    },
    "time.md is local-first. Your raw data stays on this machine. iCloud sync only shares aggregated daily summaries.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "time.md es local primero. Tus datos sin procesar permanecen en esta máquina. La sincronización con iCloud solo comparte resúmenes diarios agregados."
          }
        }
      }
    },
    "time.md will now track your screen time and sync it across your devices.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "time.md ahora rastreará tu tiempo de pantalla y lo sincronizará entre tus dispositivos."
          }
        }
      }
    },
