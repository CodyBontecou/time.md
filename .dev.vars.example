# Copy to .dev.vars for `npm run dev` / Wrangler local development.
# Never commit real secrets.

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
SITE_URL=http://localhost:8788

# Email is sent through the Cloudflare EMAIL binding configured in wrangler.toml.
# In local dev, Wrangler simulates the binding and writes emails to temp files unless configured remote.
FROM_EMAIL=cody@isolated.tech
SUPPORT_EMAIL=cody@isolated.tech

# Optional: use an existing Stripe Price instead of inline $19.99 price_data.
STRIPE_PRICE_ID=
STRIPE_UNIT_AMOUNT_CENTS=1999
STRIPE_CURRENCY=usd
STRIPE_AUTOMATIC_TAX=false

# Optional: public fallback if RELEASE_BUCKET is not bound.
TIME_MD_DOWNLOAD_URL=https://github.com/codybontecou/time.md/releases/latest

# Optional: R2 object key when RELEASE_BUCKET is bound.
TIME_MD_RELEASE_OBJECT_KEY=time.md-latest-macOS.zip
